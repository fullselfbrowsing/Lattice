Tools:
[{"description":"Look up weather for a city.","name":"lookupWeather","parameters":{"properties":{"city":{"type":"string"}},"required":["city"],"type":"object"}}]"
`;

exports[`Phase 35 prompt scaffolds > renders tool-use scaffold for mid_tier 1`] = `

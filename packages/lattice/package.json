{
  "name": "lattice",
  "version": "0.0.0",
  "description": "TypeScript-first capability runtime SDK for AI applications",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:types": "vitest --typecheck --run && tsd",
    "lint:packages": "pnpm build && publint && attw --pack . --profile esm-only"
  },
  "tsd": {
    "compilerOptions": {
      "baseUrl": ".",
      "exactOptionalPropertyTypes": true,
      "module": "ESNext",
      "noUncheckedIndexedAccess": true,
      "paths": {
        "lattice": [
          "./dist/index.d.ts"
        ]
      },
      "strict": true,
      "target": "ES2024"
    }
  },
  "dependencies": {
    "@standard-schema/spec": "catalog:",
    "canonicalize": "catalog:",
    "mime": "catalog:"
  },
  "devDependencies": {
    "@noble/ed25519": "catalog:",
    "@types/node": "catalog:",
    "zod": "catalog:"
  }
}
